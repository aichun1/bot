# ══════════════════════════════════════════
#   SuperBot — .env sozlamalari
#   Bu faylni nusxalab .env deb saqlang
# ══════════════════════════════════════════

# ─── TELEGRAM BOT ──────────────────────────
# @BotFather dan oling
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Sizning Telegram ID (https://t.me/userinfobot)
OWNER_ID=123456789

# Bot paroli (xohlagan parol yozing)
BOT_PASSWORD=MySecretPassword2024

# ─── TELEGRAM USERBOT ──────────────────────
# https://my.telegram.org → App configuration
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# Telefon raqam (+998 bilan)
PHONE=+998901234567

# SESSION_STRING (birinchi marta bo'sh qoldiring, keyin to'ldiring)
# Uni olish uchun: python get_session.py
SESSION_STRING=

# ─── GEMINI AI ─────────────────────────────
# https://aistudio.google.com → Get API Key (BEPUL)
# Audio→Text, AI chat, Rasm tahlili
GEMINI_API_KEY=AIzaSy...

# ─── AI TELEGRAM BOTLARI (eski usul, ixtiyoriy) ─────────────
# GEMINI bo'lsa bular kerak emas
# WHISPER_BOT=@whisperrobot
# AI_BOT=@ChatGPTelegramBot

# ─── GOOGLE APIS (ixtiyoriy) ───────────────
# Google Cloud Console → OAuth 2.0 → token.json faylini bu yerga paste qiling
# Yoki faylning yo'lini yozing: token.json
GOOGLE_TOKEN_JSON=token.json

# Google Calendar ID (odatda email manzilingiz)
GOOGLE_CALENDAR_ID=primary

# Gmail manzilingiz
GMAIL_USER=yourname@gmail.com
